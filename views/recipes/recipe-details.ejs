<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= pickedRecipe.name %>
    </title>
    <link rel="stylesheet" href="/css/all-and-details.css">
</head>

<body>
    <%- include('../partials/navbar') %>

        <h1>
            <%= pickedRecipe.name %>
        </h1>
        <p>Have Q ask the chef now! <a href="/chats/chat-window/<%=pickedRecipe.creator._id%>">chat</a>
        </p>
        <div class="details-buttons">
            <!-- Fav & unFav Recipe -->
            <% if (pickedRecipe.favorites.some((oneId)=> oneId.equals(user))) { %>
                <form action="/recipes/<%= pickedRecipe._id %>/unFav" method="post">
                    <button>
                        Remove Favorite
                    </button>
                </form>
                <% } else { %>
                    <form action="/recipes/<%= pickedRecipe._id %>/fav" method="post">
                        <button>
                            Add to Favorite
                        </button>
                    </form>
                    <% } %>

                        <!-- creators edit & isHidden button -->
                        <% if (pickedRecipe.creator._id.equals(user)) { %>

                            <!-- Edit -->
                            <button>
                                <a href="/recipes/<%= pickedRecipe._id %>/edit">Edit Recipe</a>
                            </button>
                            <br>
                            <!-- Delete -->
                            <a href="/recipes/delete-confirm/<%=pickedRecipe._id%>">
                                <button>
                                    <a href="/recipes/delete-confirm/<%=pickedRecipe._id%>">
                                        Delete Recipe
                                    </a>
                                </button>
                                <!-- </form> -->
                                <br>
                                <!-- isHidden -->
                                <form action=" /recipes/<%=pickedRecipe._id %>/hidden?_method=PUT" method="post">
                                    <button>
                                        <% if (pickedRecipe.isHidden) { %>
                                            Unhide Recipe
                                            <% } else { %>
                                                Hide Recipe
                                                <% } %>
                                    </button>
                                </form>
                                <% } %>
        </div>
        <div class="recipe-layout">

            <!-- Image -->
            <% if (pickedRecipe.image) { %>
                <div class="recipe-image-side">
                    <img src="/images/<%= pickedRecipe.image %>" alt="<%= pickedRecipe.name %>">
                </div>
                <% } %>


                    <!-- Content -->
                    <div class="recipe-content-side">

                        <!-- Description -->
                        <h3>Description</h3>
                        <p>
                            <%= pickedRecipe.description %>
                        </p>

                        <div class="recipe-small-details">

                            <div>
                                <h3>Preparation Time</h3>
                                <p>
                                    <%= pickedRecipe.prepTime %> minutes
                                </p>
                            </div>

                            <div>
                                <h3>Cooking Time</h3>
                                <p>
                                    <%= pickedRecipe.cookTime %> minutes
                                </p>
                            </div>

                        </div>
                        <div class="recipe-small-details">

                            <div>
                                <h3>Cuisine</h3>
                                <p>
                                    <%= pickedRecipe.cuisine %>
                                </p>
                            </div>

                            <div>
                                <h3>Category</h3>
                                <p>
                                    <%= pickedRecipe.category.name %>
                                </p>
                            </div>

                            <div>
                                <h3>Serving</h3>
                                <p>
                                    <%= pickedRecipe.serving %> people
                                </p>
                            </div>

                        </div>
                        <!-- Ingredients -->
                        <h3>Ingredients</h3>

                        <ul>
                            <% for(let oneIngred of pickedRecipe.ingredients){ %>
                                <li>
                                    🥘 <%= oneIngred.name %>
                                </li>
                                <% } %>
                        </ul>
                    </div>

        </div>
        <div class="recipe-instructions">

            <h3>Instructions</h3>

            <p>
                <%= pickedRecipe.instructions %>
            </p>

        </div>
        <div class="recipe-reviews-section">


            <div class="add-review-box">

                <h2>Add Review</h2>
                <form action="/recipes/review/<%=pickedRecipe._id%>" method="post">
                    <div class="review-inputs">

                        <div>
                            <label for="review">Your Thoughts:</label>
                            <input id="review" name="review" type="text" placeholder="Share your thoughts...">
                        </div>


                        <div>
                            <label for="rating">Rating:</label>
                            <input name="rating" id="rating" type="number" min="1" max="5" placeholder="1 - 5">
                        </div>

                    </div>

                    <button>Add Review</button>
                </form>
            </div>

            <div class="reviews-list">
                <h2>All Reviews</h2>
                <% if (pickedRecipe.review.length===0) { %>

                    <p class="no-reviews-message">
                        No reviews yet add yours now!
                    </p>

                    <% } else { %>
                        <% for (let oneReview of pickedRecipe.review) { %>

                            <div class="review-card">

                                <p class="review-text">
                                    <%= oneReview.review %>
                                </p>

                                <p class="review-stars">
                                    <% for (let i=0; i < oneReview.rating; i++) { %>
                                        ⭐
                                        <% } %>
                                </p>

                                <p class="review-author">
                                    By: <%= oneReview.creator.username %>
                                </p>

                                <% if (oneReview.creator._id.equals(user)) { %>

                                    <form
                                        action="/recipes/review/<%= pickedRecipe._id %>/<%= oneReview._id %>?_method=DELETE"
                                        method="POST">
                                        <button type="submit" class="delete-review-btn">🗑️</button>
                                    </form>

                                    <% } %>
                            </div>

                            <% } %>

                                <% } %>

            </div>


        </div>
</body>

</html>