<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Your Recipe</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../partials/navbar') %>
        <div class="recipe-form-page">

            <h1>Add Recipe</h1>

            <form class="recipe-form" action="/recipes/new" method="post" enctype="multipart/form-data">

                <!-- Information -->
                <div class="form-card">

                    <div class="form-grid">

                        <div class="form-group">
                            <label for="name">Recipe Name</label>
                            <input required type="text" id="name" name="name" placeholder="Recipe name">
                        </div>

                        <div class="form-group">
                            <label for="cuisine">Cuisine</label>
                            <select name="cuisine" id="cuisine" required>
                                <option disabled selected>Choose cuisine</option>

                                <% for(let oneCuisine of allCuisines){ %>
                                    <option value="<%= oneCuisine.name %>">
                                        <%= oneCuisine.name %>
                                    </option>
                                    <% } %>

                            </select>
                        </div>

                        <div class="form-group">
                            <label for="category">Category</label>

                            <select name="category" id="category" required>
                                <option disabled selected>Choose category</option>

                                <% for(let oneCategory of allCategories){ %>
                                    <option value="<%= oneCategory._id %>">
                                        <%= oneCategory.name %>
                                    </option>
                                    <% } %>

                            </select>
                        </div>

                        <div class="form-group">
                            <label for="serving">Serving</label>
                            <input required type="number" id="serving" name="serving">
                        </div>

                        <div class="form-group">
                            <label for="prepTime">Preparation Time</label>
                            <input type="number" id="prepTime" name="prepTime">
                        </div>

                        <div class="form-group">
                            <label for="cookTime">Cooking Time</label>
                            <input type="number" id="cookTime" name="cookTime">
                        </div>

                        <div class="form-group full-width">
                            <label for="image">Recipe Image</label>
                            <input type="file" id="image" name="image">
                        </div>

                    </div>

                </div>

                <!-- Description -->

                <div class="form-card">

                    <div class="form-group">
                        <label for="description">Description</label>

                        <textarea id="description" name="description"></textarea>

                    </div>

                </div>

                <!-- Ingredients -->

                <div class="form-card">

                    <h2>Ingredients</h2>

                    <div class="ingredients-grid">

                        <% for(let oneIng of allIngredients){ %>

                            <label class="ingredient-item">

                                <input type="checkbox" name="ingredients" value="<%= oneIng._id %>">

                                <span>
                                    <%= oneIng.name %>
                                </span>

                            </label>

                            <% } %>

                    </div>

                </div>

                <!-- Instructions -->

                <div class="form-card">

                    <div class="form-group">

                        <label for="instructions">Instructions</label>

                        <textarea id="instructions" name="instructions"></textarea>

                    </div>

                </div>

                <button>Add Recipe</button>

            </form>

        </div>
</body>

</html>